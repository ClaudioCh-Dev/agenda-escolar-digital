DATABASE_URL=postgresql://postgres:postgres@localhost:5434/agenda_escolar
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
PORT=3000
LOG_LEVEL=debug
# development → habilita Scalar en /api | production → sin documentación pública
NODE_ENV=development

# Cloudinary (adjuntos y avatares)
# Estructura: {CLOUDINARY_FOLDER}/profiles/{schoolId}/ (avatares)
#             {CLOUDINARY_FOLDER}/{schoolId}/Doc-MM-YYYY/ (documentos del mes de upload)
# Límites: adjuntos 10 MB (imagen, PDF, Word; comunicados cortos, ~10 páginas); avatar 5 MB (solo imagen)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=agenda-escolar
